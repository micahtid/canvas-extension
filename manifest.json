{
  "manifest_version": 3,
  "name": "Custom Canvas — Weekly Tasks",
  "version": "0.2.0",
  "description": "Customize the appearance of Canvas LMS — dashboard cards, sidebar, theme, and a weekly task list.",
  "key": "",
  "permissions": ["storage", "identity", "scripting"],
  "host_permissions": [
    "https://*.instructure.com/*",
    "https://canvas.unl.edu/*",
    "https://www.googleapis.com/*",
    "https://accounts.google.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Customize Canvas",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.instructure.com/*",
        "https://canvas.unl.edu/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "custom-canvas@micah.local",
      "strict_min_version": "115.0"
    }
  }
}
